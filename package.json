{
  "name": "renogent",
  "version": "0.1.0",
  "description": "An AI renovator that replaces your interior designer's coordination layer",
  "type": "module",
  "scripts": {
    "demo": "node demo/run_demo.js",
    "supervise": "node agent/bridge/supervisor.js",
    "render:candidates": "node demo/render_candidates_no_claude.js",
    "decompose:dimensions": "python3 agent/factlayer/dimension_decompose.py demo/inbox/plan-1783836724077-cropped.jpg",
    "render:whitebox:living": "python3 demo/render_living_whitebox.py",
    "render:whitebox:remaining": "npm run decompose:dimensions && python3 demo/render_remaining_whiteboxes.py",
    "render:whitebox:remaining:review": "npm run decompose:dimensions && python3 demo/render_remaining_whiteboxes.py --allow-unverified-dimensions",
    "render:whitebox:unit": "npm run render:whitebox:living && npm run render:whitebox:remaining",
    "audit:whitebox:dimensions": "npm run decompose:dimensions && python3 demo/render_remaining_whiteboxes.py --audit-only",
    "audit:render": "node agent/factlayer/release_gate.js",
    "audit:living": "python3 agent/factlayer/hooks/living_dining.py",
    "triage:live": "node agent/compliance/triage.js",
    "rfq:live": "node agent/rfq/rfq.js generate demo/recorded/triage-output.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.26.0"
  },
  "engines": {
    "node": ">=18"
  }
}
